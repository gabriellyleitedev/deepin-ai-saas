generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  leads         Lead[]
  automations   Automation[]
  conversations Conversation[]
  createdAt     DateTime @default(now())
}

model Lead {
  id            String   @id @default(cuid())
  name          String
  email         String?
  phone         String?
  status        String   @default("novo") // novo | triagem | alto-interesse | agendado | finalizado
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Conversation {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Int      @default(0)
  audioMessages Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Automation {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("ativa") // ativa | pausada | erro
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
